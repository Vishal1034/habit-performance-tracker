{
  "manifest_version": 3,
  "name": "Habit Stability Tracker",
  "version": "1.0",
  "description": "Tracks browsing activity for the Habit Stability Tracker dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:5000/*" 
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
